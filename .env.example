# Database (PostgreSQL - ook lokaal via Docker)
# Lokaal met Docker: docker run --name pg-xfactor -e POSTGRES_PASSWORD=devpassword -e POSTGRES_DB=activiteiten_xfactor -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:devpassword@localhost:5432/activiteiten_xfactor"
# Azure productie:
# DATABASE_URL="postgresql://user:password@host.postgres.database.azure.com:5432/activiteiten_xfactor?sslmode=require"

# Authentication (genereer met: openssl rand -base64 32)
AUTH_SECRET="your-super-secret-key-minimum-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Azure AD SSO (optioneel - laat leeg om enkel credentials login te gebruiken)
AZURE_AD_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_AD_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AZURE_AD_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# File uploads
# Lokaal:
UPLOAD_DIR="./uploads"
# Azure (productie):
# AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx"
# AZURE_STORAGE_CONTAINER="uploads"

# App
NODE_ENV="development"
NEXT_PUBLIC_ENVIRONMENT="development"

# Optional: Application Insights (Azure)
# APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=xxx"
